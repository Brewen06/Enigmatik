{% extends 'base.html.twig' %}

{% block title %}Liste des énigmes{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0 text-white">Liste des énigmes</h1>
        <a href="{{ path('app_enigme_creer') }}" class="btn btn-light btn-sm">
            <i class="bi bi-plus-lg"></i> Créer une énigme
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Ordre</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Consigne</th>
                        <th>Lien</th>
                        <th>Code Secret</th>
                        <th>Vignette</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for enigme in enigmes %}
                    <tr>
                        <td>{{ enigme.id }}</td>
                        <td>{{ enigme.ordre }}</td>
                        <td>{{ enigme.titre }}</td>
                        <td>{{ enigme.type.libelle }}</td>
                        <td>{{ enigme.consigne|slice(0, 100) }}...</td>
                        <td>{{ enigme.lien }}</td>
                        <td>{{ enigme.codeSecret }}</td>
                        <td>
                            {% if enigme.vignette %}
                                <img src="{{ asset(enigme.vignette.image | replace({'public/': ''})) }}" alt="{{ enigme.vignette.information }}" width="50" class="img-thumbnail">
                            {% else %}
                                <span class="text-muted">Aucune</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_enigme_show', {'id': enigme.id}) }}" class="btn btn-info btn-sm text-white" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_enigme_edit', {'id': enigme.id}) }}" class="btn btn-warning btn-sm text-white" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center py-4">Aucune énigme trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('enigme/supprimer-toutes.html.twig') }}
    </div>
</div>
{% endblock %}
