{% extends 'base.html.twig' %}

{% block title %}Détails Enigme{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h1 class="h3 mb-0 fw-bold"><i class="bi bi-puzzle-fill me-2"></i>Détails de l'énigme</h1>
            <span class="badge bg-light text-primary fs-6">#{{ enigme.id }}</span>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-8">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-primary mb-0">{{ enigme.titre }}</h4>
                        <span class="badge bg-info text-dark">{{ enigme.type.libelle }}</span>
                    </div>
                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase small fw-bold">Consigne</h6>
                        <p class="lead bg-light p-3 rounded border-start border-4 border-primary">{{ enigme.consigne|nl2br }}</p>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold">Ordre</h6>
                            <p class="fs-5">{{ enigme.ordre }}</p>
                        </div>
                        {% if is_granted('ROLE_ADMIN') %}
                        <div class="col-md-6">
                            <h6 class="text-muted text-uppercase small fw-bold">Code Secret</h6>
                            <p class="fs-5 font-monospace bg-dark text-warning d-inline-block px-2 rounded">{{ enigme.codeSecret }}</p>
                        </div>
                        {% endif %}
                    </div>
                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase small fw-bold">Lien associé</h6>
                        {% if enigme.lien %}
                            <a href="{{ enigme.lien }}" target="_blank" class="btn btn-outline-primary">
                                <i class="bi bi-link-45deg me-1"></i> Ouvrir le lien
                            </a>
                        {% else %}
                            <p class="text-muted fst-italic">Aucun lien associé</p>
                        {% endif %}
                    </div>

                    <div {{ stimulus_controller('game', { 'checkUrl': path('app_enigme_check', {'id': enigme.id}) }) }}>
                        <form {{ stimulus_action('game', 'check', 'submit') }} class="mt-4">
                            {% if enigme.choices is not empty %}
                                <div class="mb-3">
                                    <p class="fw-bold mb-2">Choisissez la bonne réponse :</p>
                                    {% for choice in enigme.choices %}
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="radio" name="answer" id="choice_{{ loop.index }}" value="{{ choice }}" {{ stimulus_target('game', 'input') }}>
                                            <label class="form-check-label" for="choice_{{ loop.index }}">
                                                {{ choice }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>
                                <button class="btn btn-primary w-100" type="submit">Vérifier</button>
                            {% else %}
                                <div class="input-group mb-3">
                                    <input type="text" class="form-control form-control-lg" placeholder="Entrez le code secret..." {{ stimulus_target('game', 'input') }}>
                                    <button class="btn btn-primary" type="submit">Vérifier</button>
                                </div>
                            {% endif %}
                        </form>
                        <div {{ stimulus_target('game', 'result') }}></div>
                        <div class="mt-3 d-none" {{ stimulus_target('game', 'nextButton') }}>
                            <a href="{{ path('app_jeu_index') }}" class="btn btn-success">Retour au jeu</a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card bg-light border-0 h-100">
                        <div class="card-body text-center">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Vignette associée</h6>
                            {% if enigme.vignette %}
                                <img src="{{ asset(enigme.vignette.image | replace({'public/': ''})) }}" alt="{{ enigme.vignette.information }}" class="img-fluid rounded shadow-sm mb-2" style="max-height: 200px;">
                                <p class="small text-muted fst-italic">{{ enigme.vignette.information }}</p>
                            {% else %}
                                <div class="py-5 text-muted">
                                    <i class="bi bi-image fs-1 d-block mb-2"></i>
                                    Aucune vignette
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-4">

            <div class="d-flex justify-content-between align-items-center">
                <a href="{{ path('app_jeu_index') }}" class="btn btn-success">Retour au jeu</a>
                {% if is_granted('ROLE_PROF') or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_enigme_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Retour à la liste
                </a>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_enigme_edit', {'id': enigme.id}) }}" class="btn btn-warning text-white">
                            <i class="bi bi-pencil-square me-1"></i> Modifier
                        </a>
                        {{ include('enigme/_delete_form.html.twig') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
