{{ form_start(form, {'attr': {'class': 'enigme-form'}}) }}
    <div class="enigme-form__section">
        <h2 class="enigme-form__section-title">Informations générales</h2>
        <div class="row g-3">
            <div class="col-md-4">{{ form_row(form.ordre) }}</div>
            <div class="col-md-8">{{ form_row(form.titre) }}</div>
            <div class="col-md-6">{{ form_row(form.type) }}</div>
            <div class="col-md-6">{{ form_row(form.vignette) }}</div>
            <div class="col-12" id="bloc-image-requise" style="display: none;">
                <div class="alert alert-info mb-0">
                    Ce type d'énigme utilise des images. Ajoutez au moins un <strong>lien</strong> ou une <strong>vignette</strong>.
                </div>
            </div>
            <div class="col-12" id="bloc-frise-modele" style="display: none;">
                <div class="frise-form-panel">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                        <h3 class="h6 mb-0">Configuration de la frise</h3>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-reset-frise-form">Réinitialiser</button>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">{{ form_row(form.yearStart) }}</div>
                        <div class="col-md-6">{{ form_row(form.yearEnd) }}</div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <label class="btn btn-primary btn-sm mb-0">
                            <i class="bi bi-cloud-upload me-1"></i>Importer des images
                            <input type="file" accept="image/*" multiple hidden data-frise-upload>
                        </label>
                        <input type="hidden" data-frise-upload-token value="{{ csrf_token('vignette_quick_upload') }}">
                        <input type="hidden" data-frise-delete-token value="{{ csrf_token('vignette_quick_delete') }}">
                    </div>

                    <p class="mb-3 text-muted small">
                        Glissez les images depuis la banque vers la frise pour fixer leur année, puis ajustez leur position horizontale.
                    </p>

                    {{ form_widget(form.frisePayload) }}

                    <div class="frise-form-editor" data-frise-form-editor data-upload-url="{{ path('app_vignette_quick_upload') }}" data-delete-url="{{ path('app_vignette_quick_delete') }}" data-initial-order="{{ friseItemsForm|default([])|json_encode|e('html_attr') }}">
                        <div class="frise-form-dropzone frise-form-dropzone--bank" data-frise-form-bank>
                            {% for vignette in availableVignettes|default([]) %}
                                <article class="frise-form-card" draggable="true" data-vignette-id="{{ vignette.id }}" data-vignette-image="{{ vignette.image }}" data-vignette-label="{{ vignette.information }}">
                                    <img src="{{ asset(vignette.image|replace({'public/': ''})) }}" alt="{{ vignette.information }}">
                                    <p>{{ vignette.information|slice(0, 70) }}</p>
                                    <div class="frise-form-card__actions">
                                        <button type="button" class="btn btn-sm btn-outline-danger" data-action="delete"><i class="bi bi-trash"></i></button>
                                    </div>
                                </article>
                            {% else %}
                                <p class="text-muted fst-italic mb-0">Aucune vignette disponible.</p>
                            {% endfor %}
                        </div>

                        <div class="frise-form-board mt-3">
                            
                            <div class="frise-form-axis frise-form-axis--board mt-3" data-frise-form-axis>
                                <div class="frise-form-line"></div>
                                <div class="frise-form-ruler" data-frise-form-ruler></div>
                                <div class="frise-form-canvas" data-frise-form-canvas></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">{{ form_row(form.consigne) }}</div>
            <div class="col-12" id="bloc-lien">{{ form_row(form.lien) }}</div>
            <div class="col-12">{{ form_row(form.indice) }}</div>
        </div>
    </div>

    <div class="enigme-form__section">
        <h2 class="enigme-form__section-title">Configuration de la réponse</h2>
        {{ form_row(form.reponseType) }}

        <div id="bloc-multiple">{{ form_row(form.choices) }}</div>
        {{ form_row(form.solution) }}
    </div>

    {{ form_rest(form) }}

    <div class="enigme-form__actions mt-3">
        {% if back_path is defined and back_path %}
            <a href="{{ back_path }}" class="btn btn-outline-secondary">Retour à la liste</a>
        {% endif %}
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    </div>
{{ form_end(form) }}

<script>
function initEnigmeReponseTypeToggle() {
    const name = '{{ form.reponseType.vars.full_name }}';
    const radios = document.querySelectorAll(`input[name="${name}"]`);
    const blocMultiple = document.getElementById('bloc-multiple');
    const inputMultiple = document.getElementById('{{ form.choices.vars.id }}');

    if (!radios.length) {
        return;
    }

    function refresh() {
        const selected = document.querySelector(`input[name="${name}"]:checked`)?.value;
        const isLibre = selected === 'libre';

        if (blocMultiple) {
            blocMultiple.style.display = isLibre ? 'none' : '';
        }

        if (inputMultiple) {
            inputMultiple.disabled = isLibre;
        }
    }

    radios.forEach((radio) => {
        if (radio.dataset.choicesToggleBound === '1') {
            return;
        }

        radio.addEventListener('change', refresh);
        radio.dataset.choicesToggleBound = '1';
    });

    refresh();
}

function initTypeHelpers() {
    const typeSelect = document.getElementById('{{ form.type.vars.id }}');
    const imageBlock = document.getElementById('bloc-image-requise');
    const friseBlock = document.getElementById('bloc-frise-modele');
    const consigneInput = document.getElementById('{{ form.consigne.vars.id }}');
    const choicesInput = document.getElementById('{{ form.choices.vars.id }}');
    const solutionInput = document.getElementById('{{ form.solution.vars.id }}');
    const frisePayloadInput = document.getElementById('{{ form.frisePayload.vars.id }}');

    if (!typeSelect) {
        return;
    }

    function refreshTypeBlocks() {
        const selected = typeSelect.options[typeSelect.selectedIndex];
        const reponseSection = document.querySelector('.enigme-form__section:nth-of-type(2)');
        const solutionInput = document.getElementById('{{ form.solution.vars.id }}');
        const choicesInput = document.getElementById('{{ form.choices.vars.id }}');
        const reponseTypeInputs = document.querySelectorAll('input[name="{{ form.reponseType.vars.full_name }}"]');

        if (!selected) {
            if (imageBlock) {
                imageBlock.style.display = 'none';
            }
            if (friseBlock) {
                friseBlock.style.display = 'none';
            }
            if (reponseSection) {
                reponseSection.style.display = '';
            }
            if (solutionInput) {
                solutionInput.disabled = false;
            }
            if (choicesInput) {
                choicesInput.disabled = false;
            }
            if (frisePayloadInput) {
                frisePayloadInput.disabled = true;
            }
            reponseTypeInputs.forEach((input) => {
                input.disabled = false;
            });
            return;
        }

        const label = (selected.textContent || '').trim().toLowerCase();
        const imageUsage = selected.dataset.imageUsage || 'non';
        const isFrise = label.includes('frise');
        const requiresImage = imageUsage !== 'non';

        if (imageBlock) {
            imageBlock.style.display = requiresImage ? '' : 'none';
        }

        if (friseBlock) {
            friseBlock.style.display = isFrise ? '' : 'none';
        }

        if (reponseSection) {
            reponseSection.style.display = isFrise ? 'none' : '';
        }

        if (solutionInput) {
            solutionInput.disabled = isFrise;
        }

        if (choicesInput) {
            choicesInput.disabled = isFrise;
        }

        if (consigneInput && isFrise && !consigneInput.value.trim()) {
            consigneInput.value = "Replace les images dans l'ordre chronologique, du plus ancien au plus récent.";
        }

        if (frisePayloadInput) {
            frisePayloadInput.disabled = !isFrise;
        }

        reponseTypeInputs.forEach((input) => {
            input.disabled = isFrise;
        });
    }

    if (typeSelect.dataset.bindTypeHelpers !== '1') {
        typeSelect.addEventListener('change', refreshTypeBlocks);
        typeSelect.dataset.bindTypeHelpers = '1';
    }

    refreshTypeBlocks();
}

function initFriseConfiguratorInForm() {
    const editor = document.querySelector('[data-frise-form-editor]');
    const payloadInput = document.getElementById('{{ form.frisePayload.vars.id }}');
    const resetButton = document.getElementById('btn-reset-frise-form');
    const yearStartInput = document.getElementById('{{ form.yearStart.vars.id }}');
    const yearEndInput = document.getElementById('{{ form.yearEnd.vars.id }}');
    const uploadInput = document.querySelector('[data-frise-upload]');
    const uploadTokenInput = document.querySelector('[data-frise-upload-token]');
    const deleteTokenInput = document.querySelector('[data-frise-delete-token]');
    const uploadUrl = editor?.dataset.uploadUrl || '';
    const deleteUrl = editor?.dataset.deleteUrl || '';

    if (!editor || !payloadInput || editor.dataset.boundFriseFormEditor === '1') {
        return;
    }

    const bank = editor.querySelector('[data-frise-form-bank]');
    const axis = editor.querySelector('[data-frise-form-axis]');
    const canvas = editor.querySelector('[data-frise-form-canvas]');
    const ruler = editor.querySelector('[data-frise-form-axis] [data-frise-form-ruler]');

    if (!bank || !axis || !canvas) {
        return;
    }

    let draggedCard = null;
    let draggingMarkerId = null;
    let draggingPointerId = null;
    const state = { placed: [] };

    function cardsIn(container) {
        return Array.from(container.querySelectorAll('.frise-form-card'));
    }

    function findCardById(vignetteId) {
        return bank.querySelector(`.frise-form-card[data-vignette-id="${vignetteId}"]`);
    }

    function findPlaced(vignetteId) {
        return state.placed.find((item) => item.id === vignetteId) || null;
    }

    function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
    }

    function percentFromPointer(clientX) {
        const rect = axis.getBoundingClientRect();
        if (rect.width <= 0) {
            return 50;
        }

        return clamp(((clientX - rect.left) / rect.width) * 100, 0, 100);
    }

    function createCard(vignette) {
        const card = document.createElement('article');
        card.className = 'frise-form-card';
        card.draggable = true;
        card.dataset.vignetteId = String(vignette.id || '');
        card.dataset.vignetteImage = String(vignette.image || '');
        card.dataset.vignetteLabel = String(vignette.information || 'Vignette');

        card.innerHTML = `
            <img src="/${String(vignette.image || '').replace(/^public\//, '')}" alt="${String(vignette.information || 'Vignette')}">
            <p>${String(vignette.information || 'Vignette')}</p>
            <div class="frise-form-card__actions">
                <button type="button" class="btn btn-sm btn-outline-danger" data-action="delete"><i class="bi bi-trash"></i></button>
            </div>
        `;

        return card;
    }

    function placeOnTimeline(vignetteId, x) {
        const nextX = clamp(x, 0, 100);
        const existing = findPlaced(vignetteId);

        if (existing) {
            existing.x = nextX;
        } else {
            state.placed.push({ id: vignetteId, x: nextX });
        }

        render();
    }

    function removeFromTimeline(vignetteId) {
        state.placed = state.placed.filter((item) => item.id !== vignetteId);
        render();
    }

    function buildMarker(placedItem) {
        const card = findCardById(placedItem.id);
        if (!card) {
            return null;
        }

        const image = card.dataset.vignetteImage || '';
        const label = card.dataset.vignetteLabel || 'Vignette';
        const { start, end } = getYearBounds();
        const range = Math.max(1, end - start);
        const markerYear = Math.round(start + (clamp(placedItem.x, 0, 100) / 100) * range);

        const marker = document.createElement('article');
        marker.className = 'frise-form-marker';
        marker.dataset.vignetteId = placedItem.id;
        marker.style.left = `${placedItem.x}%`;

        marker.innerHTML = `
            <span class="frise-form-marker-year">${markerYear}</span>
            <button type="button" class="frise-form-marker-remove" title="Retirer">×</button>
            <img src="/${String(image).replace(/^public\//, '')}" alt="${label}">
            <span>${label}</span>
        `;

        marker.addEventListener('pointerdown', (event) => {
            draggingMarkerId = placedItem.id;
            draggingPointerId = event.pointerId;
            event.preventDefault();
        });

        const removeButton = marker.querySelector('.frise-form-marker-remove');
        removeButton?.addEventListener('pointerdown', (event) => {
            event.preventDefault();
            event.stopPropagation();
        });
        removeButton?.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            removeFromTimeline(placedItem.id);
        });

        return marker;
    }

    function refreshPayload() {
        const ids = state.placed
            .slice()
            .sort((a, b) => a.x - b.x)
            .map((item) => Number(item.id || 0))
            .filter((id) => id > 0);

        payloadInput.value = JSON.stringify(ids);
    }

    function renderCanvas() {
        canvas.innerHTML = '';

        if (state.placed.length === 0) {
            const empty = document.createElement('p');
            empty.className = 'frise-form-canvas-empty';
            empty.textContent = 'Glissez une image depuis la galerie.';
            canvas.appendChild(empty);
            return;
        }

        state.placed
            .slice()
            .sort((a, b) => a.x - b.x)
            .forEach((item, index) => {
                const marker = buildMarker(item);
                if (!marker) {
                    return;
                }

                const badge = document.createElement('div');
                badge.className = 'frise-form-step';
                badge.textContent = String(index + 1);
                marker.appendChild(badge);

                canvas.appendChild(marker);
            });
    }

    function render() {
        refreshPayload();
        renderCanvas();
    }

    function getYearBounds() {
        const parsedStart = parseInt(yearStartInput?.value || '', 10);
        const parsedEnd = parseInt(yearEndInput?.value || '', 10);
        const start = Number.isFinite(parsedStart) ? parsedStart : 1960;
        const end = Number.isFinite(parsedEnd) ? parsedEnd : 2025;

        if (end <= start) {
            return { start, end: start + 1 };
        }

        return { start, end };
    }

    function renderRuler() {
        if (!ruler) {
            return;
        }

        ruler.innerHTML = '';
        const { start, end } = getYearBounds();
        const range = Math.max(1, end - start);
        const step = range <= 10 ? 1 : range <= 50 ? 5 : 10;

        for (let year = start; year <= end; year += step) {
            const percent = ((year - start) / range) * 100;

            const tick = document.createElement('span');
            tick.className = 'frise-form-tick';
            tick.style.left = `${percent}%`;

            const label = document.createElement('span');
            label.className = 'frise-form-year';
            label.style.left = `${percent}%`;
            label.textContent = String(year);

            ruler.appendChild(tick);
            ruler.appendChild(label);
        }

        if ((end - start) % step !== 0) {
            const endTick = document.createElement('span');
            endTick.className = 'frise-form-tick';
            endTick.style.left = '100%';

            const endLabel = document.createElement('span');
            endLabel.className = 'frise-form-year';
            endLabel.style.left = '100%';
            endLabel.textContent = String(end);

            ruler.appendChild(endTick);
            ruler.appendChild(endLabel);
        }
    }

    async function deleteCard(card) {
        const vignetteId = String(card.dataset.vignetteId || '');
        const numericId = Number(vignetteId || 0);

        if (numericId <= 0 || !deleteUrl) {
            removeFromTimeline(vignetteId);
            card.remove();
            render();
            return;
        }

        const confirmDelete = window.confirm('Supprimer cette image ?');
        if (!confirmDelete) {
            return;
        }

        try {
            const formData = new FormData();
            formData.append('_token', deleteTokenInput?.value || '');
            formData.append('id', String(numericId));

            const response = await fetch(deleteUrl, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            const data = await response.json();
            if (response.ok && data.success) {
                removeFromTimeline(vignetteId);
                card.remove();
                render();
            }
        } catch (error) {
            console.warn('Suppression impossible.', error);
        }
    }

    function bindCard(card) {
        if (card.dataset.dragBound === '1') {
            return;
        }

        card.addEventListener('dragstart', () => {
            draggedCard = card;
            card.classList.add('dragging');
        });

        card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
            draggedCard = null;
        });

        card.querySelector('[data-action="delete"]')?.addEventListener('click', () => {
            deleteCard(card);
        });

        card.dataset.dragBound = '1';
    }

    function handleDragOverBank(container, event) {
        event.preventDefault();
        if (!draggedCard) {
            return;
        }

        const targetCard = event.target.closest('.frise-form-card');
        if (!targetCard || targetCard === draggedCard || targetCard.parentElement !== container) {
            return;
        }

        const rect = targetCard.getBoundingClientRect();
        const before = event.clientY < rect.top + rect.height / 2;

        container.insertBefore(draggedCard, before ? targetCard : targetCard.nextSibling);
    }

    function handleDropOnAxis(event) {
        event.preventDefault();
        if (!draggedCard) {
            return;
        }

        const vignetteId = String(draggedCard.dataset.vignetteId || '');
        if (vignetteId) {
            placeOnTimeline(vignetteId, percentFromPointer(event.clientX));
        }
    }

    bank.addEventListener('dragover', (event) => handleDragOverBank(bank, event));
    bank.addEventListener('drop', (event) => {
        event.preventDefault();
        draggedCard = null;
    });

    axis.addEventListener('dragover', (event) => {
        event.preventDefault();
        if (event.dataTransfer) {
            event.dataTransfer.dropEffect = 'copy';
        }
    });
    axis.addEventListener('drop', handleDropOnAxis);

    document.addEventListener('pointermove', (event) => {
        if (!draggingMarkerId) {
            return;
        }

        if (draggingPointerId !== null && event.pointerId !== draggingPointerId) {
            return;
        }

        const marker = findPlaced(draggingMarkerId);
        if (!marker) {
            return;
        }

        marker.x = percentFromPointer(event.clientX);
        render();
    });
    document.addEventListener('pointerup', () => {
        draggingMarkerId = null;
        draggingPointerId = null;
    });
    document.addEventListener('pointercancel', () => {
        draggingMarkerId = null;
        draggingPointerId = null;
    });

    if (yearStartInput && yearStartInput.dataset.boundFriseRuler !== '1') {
        yearStartInput.addEventListener('input', renderRuler);
        yearStartInput.addEventListener('change', renderRuler);
        yearStartInput.dataset.boundFriseRuler = '1';
    }

    if (yearEndInput && yearEndInput.dataset.boundFriseRuler !== '1') {
        yearEndInput.addEventListener('input', renderRuler);
        yearEndInput.addEventListener('change', renderRuler);
        yearEndInput.dataset.boundFriseRuler = '1';
    }

    cardsIn(editor).forEach(bindCard);

    if (resetButton && resetButton.dataset.boundResetFriseForm !== '1') {
        resetButton.addEventListener('click', () => {
            state.placed = [];
            render();
        });
        resetButton.dataset.boundResetFriseForm = '1';
    }

    if (uploadInput && uploadInput.dataset.boundUploadFrise !== '1') {
        uploadInput.addEventListener('change', async (event) => {
            const files = Array.from(event.target.files || []);

            for (const file of files) {
                if (!file.type.startsWith('image/') || !uploadUrl) {
                    continue;
                }

                try {
                    const formData = new FormData();
                    formData.append('_token', uploadTokenInput?.value || '');
                    formData.append('file', file);
                    formData.append('information', file.name.replace(/\.[^.]+$/, ''));

                    const response = await fetch(uploadUrl, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const data = await response.json();
                    if (response.ok && data.success && data.vignette) {
                        const card = createCard(data.vignette);
                        bank.appendChild(card);
                        bindCard(card);
                    }
                } catch (error) {
                    console.warn('Upload de vignette impossible.', error);
                }
            }

            uploadInput.value = '';
            render();
        });
        uploadInput.dataset.boundUploadFrise = '1';
    }

    const initialRaw = editor.dataset.initialOrder || '[]';
    try {
        const initialItems = JSON.parse(initialRaw);
        if (Array.isArray(initialItems) && initialItems.length > 0) {
            const ordered = initialItems
                .map((item) => ({
                    vignetteId: Number(item.vignetteId || 0),
                    position: Number(item.position || 0),
                }))
                .filter((item) => item.vignetteId > 0 && item.position > 0)
                .sort((a, b) => a.position - b.position);

            ordered.forEach((item) => {
                const card = findCardById(String(item.vignetteId));
                if (!card) {
                    return;
                }

                const x = ordered.length > 1
                    ? 8 + ((item.position - 1) * 84) / (ordered.length - 1)
                    : 50;

                state.placed.push({ id: String(item.vignetteId), x });
            });
        }
    } catch (error) {
        console.warn('Impossible de lire les données initiales de la frise.', error);
    }

    render();
    renderRuler();
    editor.dataset.boundFriseFormEditor = '1';
}

document.addEventListener('DOMContentLoaded', initEnigmeReponseTypeToggle);
document.addEventListener('turbo:load', initEnigmeReponseTypeToggle);
document.addEventListener('DOMContentLoaded', initTypeHelpers);
document.addEventListener('turbo:load', initTypeHelpers);
document.addEventListener('DOMContentLoaded', initFriseConfiguratorInForm);
document.addEventListener('turbo:load', initFriseConfiguratorInForm);
</script>

<style>
    .frise-form-panel {
        border-radius: 1.25rem;
        background: linear-gradient(135deg, #f8ecdb 0%, #f5e8d0 100%);
        padding: 1.15rem;
        box-shadow: 0 6px 20px rgba(77, 92, 120, 0.12);
    }

    .frise-form-editor {
        display: grid;
        gap: 1rem;
    }

    .frise-form-dropzone {
        min-height: 120px;
        border: 2px dashed #c8b88f;
        border-radius: 0.95rem;
        background: #fff7df;
        padding: 0.85rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        align-items: flex-start;
    }

    .frise-form-dropzone--bank {
        max-height: 320px;
        overflow: auto;
    }

    .frise-form-dropzone--track {
        min-height: 145px;
    }

    .frise-form-axis--board {
        position: relative;
        min-height: 360px;
        border: 2px solid #d6c79f;
        border-radius: 0.95rem;
        background: linear-gradient(180deg, #fbf2d6 0%, #fbeee0 100%);
        padding: 1rem;
    }

    .frise-form-axis--board .frise-form-line {
        position: absolute;
        top: 88px;
        left: 1rem;
        right: 1rem;
    }

    .frise-form-axis--board .frise-form-ruler {
        position: absolute;
        top: 100px;
        left: 1rem;
        right: 1rem;
        height: 30px;
    }

    .frise-form-canvas {
        position: absolute;
        inset: 0;
    }

    .frise-form-canvas-empty {
        position: absolute;
        top: 68%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #8a9aad;
        margin: 0;
        font-size: 0.95rem;
        font-weight: 500;
        white-space: nowrap;
        pointer-events: none;
    }

    .frise-form-marker {
        position: absolute;
        top: 32px;
        transform: translateX(-50%);
        width: 180px;
        border: 1px solid #d8e4f6;
        border-radius: 0.9rem;
        background: #fff;
        box-shadow: 0 4px 12px rgba(26, 43, 73, 0.08);
        padding: 0.5rem;
        cursor: grab;
