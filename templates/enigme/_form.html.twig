{{ form_start(form) }}
{{ form_row(form.reponseType) }}

<div id="bloc-libre">
    {{ form_row(form.codeSecret) }}
</div>

<div id="bloc-multiple">
    {{ form_row(form.choices) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const name = '{{ form.reponseType.vars.full_name }}';
    const radios = document.querySelectorAll(`input[name="${name}"]`);
    const blocLibre = document.getElementById('bloc-libre');
    const blocMultiple = document.getElementById('bloc-multiple');
    const inputLien = document.getElementById('bloc-lien');
    const inputCodeSecret = document.getElementById('{{ form.codeSecret.vars.id }}');
    const inputMultiple = document.getElementById('{{ form.choices.vars.id }}');

    function refresh() {
        const selected = document.querySelector(`input[name="${name}"]:checked`)?.value;
        const isLibre = selected === 'libre';

        blocLibre.style.display = isLibre ? '' : 'none';
        blocMultiple.style.display = isLibre ? 'none' : '';

        inputCodeSecret.disabled = !isLibre;
        inputLien.disabled = isLibre;
        inputMultiple.disabled = isLibre;
    }

    radios.forEach(r => r.addEventListener('change', refresh));
    refresh();
});
</script>
    {{ form_widget(form) }}
    <div class="mt-3">
        <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    </div>
{{ form_end(form) }}
