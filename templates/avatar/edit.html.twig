{% extends 'base.html.twig' %}

{% block title %}Modifier l'avatar{% endblock %}

{% block body %}
<section class="edit-page">
    <div class="edit-page__card">
        <div class="edit-page__header">
            <h1 class="edit-page__title">Modifier l'avatar</h1>
            <p class="edit-page__subtitle">Mettez à jour les informations et validez les changements.</p>
        </div>

        {{ include('avatar/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <div class="edit-page__actions mt-4 d-flex flex-wrap gap-2">
            <a href="{{ path('app_avatar_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
            {{ include('avatar/_delete_form.html.twig') }}
        </div>
    </div>
</section>
{% endblock %}
