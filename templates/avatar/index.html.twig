{% extends 'base.html.twig' %}

{% block title %}Liste des avatars{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0 text-white">Liste des avatars</h1>
        <a href="{{ path('app_avatar_new') }}" class="btn btn-light btn-sm">
            <i class="bi bi-plus-lg"></i> Créer un avatar
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Aperçu</th>
                        <th>Nom</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for avatar in avatars %}
                    <tr>
                        <td>{{ avatar.id }}</td>
                        <td>
                            {% if avatar.image %}
                                <img src="{{ asset(avatar.image | replace({'public/': ''})) }}" alt="{{ avatar.nom }}" width="50" height="50" class="rounded-circle border">
                            {% else %}
                                <span class="text-muted small">Aucune image</span>
                            {% endif %}
                        </td>
                        <td>{{ avatar.nom }}</td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_avatar_show', {'id': avatar.id}) }}" class="btn btn-info btn-sm text-white" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_avatar_edit', {'id': avatar.id}) }}" class="btn btn-warning btn-sm text-white" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center py-4">Aucun avatar trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
