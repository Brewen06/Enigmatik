{% extends 'base.html.twig' %}

{% block title %}Détails Avatar{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h1 class="h3 mb-0 text-white">Détails de l'avatar</h1>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th class="w-25 bg-light">Id</th>
                        <td>{{ avatar.id }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Nom</th>
                        <td>{{ avatar.nom }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Image</th>
                        <td>
                            {% if avatar.image %}
                                <img src="{{ asset(avatar.image | replace({'public/': ''})) }}" alt="{{ avatar.nom }}" class="img-thumbnail" style="max-width: 200px;">
                            {% else %}
                                <span class="text-muted">Aucune image</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_avatar_index') }}" class="btn btn-secondary">
                    &larr; Retour à la liste
                </a>
                <a href="{{ path('app_avatar_edit', {'id': avatar.id}) }}" class="btn btn-warning text-white">
                    Modifier
                </a>
                {{ include('avatar/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
