{% extends 'base.html.twig' %}

{% block title %}Enigmatik - Jeu{% endblock %}

{% block body %}
    <div class="tw-text-center tw-mb-10">
        <h1 class="tw-text-4xl tw-font-bold tw-mb-2">Bienvenue <span class="tw-text-blue-600">{% if equipe %}{{ equipe.nom }}{% endif %}</span> !</h1>
        <p class="tw-text-lg tw-text-gray-600">Prêt à relever le défi ? Résolvez les énigmes pour obtenir les indices du code final.</p>
    </div>

    {% if equipe %}
        <div class="tw-max-w-md tw-mx-auto tw-bg-white tw-rounded-xl tw-shadow tw-p-4 tw-mb-8 tw-flex tw-items-center tw-gap-4">
            {% if equipe.avatar %}
                <img src="{{ asset(equipe.avatar.image) }}" alt="{{ equipe.avatar.nom }}" class="tw-w-16 tw-h-16 tw-rounded-full tw-object-cover tw-border tw-border-gray-200">
            {% endif %}
            <div>
                <p class="tw-text-xs tw-uppercase tw-text-gray-500 tw-mb-1">Données de l'équipe</p>
                <p class="tw-font-semibold tw-text-gray-900 tw-mb-0">{{ equipe.nom }}</p>
                {% if equipe.avatar %}
                    <p class="tw-text-sm tw-text-gray-600 tw-mb-0">Avatar : {{ equipe.avatar.nom }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="tw-container tw-relative tw-mx-auto tw-px-4" 
         data-controller="board" 
         data-board-validate-url-value="{{ path('app_jeu_validate_final_code') }}"
         data-board-victory-url-value="{{ path('app_jeu_victoire') }}"
         data-board-team-id-value="{{ equipe ? equipe.id : 0 }}"
         data-board-timer-seconds-value="{{ timerSeconds }}">
        <div data-board-target="modal" class="tw-hidden tw-absolute tw-inset-0 tw-z-50 tw-flex tw-items-center tw-justify-center tw-p-4 tw-bg-black tw-bg-opacity-75 tw-backdrop-blur-sm tw-overflow-y-auto">
            <div class="tw-bg-white tw-rounded-xl tw-p-8 tw-max-w-2xl tw-w-full tw-my-4 tw-relative tw-shadow-2xl tw-border-4 tw-border-green-500">
                <button data-action="click->board#closeModal" class="tw-absolute tw-top-4 tw-right-4 tw-text-gray-400 hover:tw-text-gray-800 tw-transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-h-8 tw-w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                
                <div class="tw-text-center">
                    <h2 class="tw-text-3xl tw-font-bold tw-text-green-700 tw-mb-6">Débriefing de mission</h2>
                    <div class="tw-text-left tw-bg-green-50 tw-p-6 tw-rounded-lg tw-border tw-border-green-200">
                        <p class="tw-text-lg tw-text-gray-800 tw-mb-4">
                            <strong class="tw-font-bold">Bienvenue {{ equipe ? equipe.nom : 'équipe' }}.</strong><br>
                            Votre mission consiste à résoudre des énigmes en informatique pour collecter les indices nécessaires à l'ouverture du verrou final.
                        </p>
                        <ul class="tw-space-y-3 tw-text-gray-700">
                            <li class="tw-flex tw-items-start">
                                Analysez chaque consigne avec méthode et validez les énigmes une par une.
                            </li>
                            <li class="tw-flex tw-items-start">
                                Exploitez les indices obtenus pour reconstituer le code final de votre équipe.
                            </li>
                            <li class="tw-flex tw-items-start">
                                Saisissez le code final dans la zone dédiée pour terminer la mission.
                            </li>
                        </ul>
                    </div>
                    
                    <button data-action="click->board#closeModal" class="tw-mt-8 tw-px-8 tw-py-3 tw-bg-green-600 hover:tw-bg-green-700 tw-text-white tw-font-bold tw-rounded-full tw-shadow-lg tw-transition-transform hover:tw-scale-105">
                        J'ACCEPTE LA MISSION
                    </button>
                </div>
            </div>
        </div>

        <div data-board-target="enigmaModal" class="tw-hidden tw-absolute tw-inset-0 tw-z-50 tw-flex tw-items-center tw-justify-center tw-p-4 tw-bg-black tw-bg-opacity-75 tw-backdrop-blur-sm tw-overflow-y-auto">
            <div class="tw-bg-white tw-rounded-xl tw-p-8 tw-max-w-lg tw-w-full tw-relative tw-shadow-2xl tw-border-4 tw-border-blue-500">
                <button data-action="click->board#closeEnigmaModal" class="tw-absolute tw-top-4 tw-right-4 tw-text-gray-400 hover:tw-text-gray-800 tw-transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-h-8 tw-w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                
                <div class="tw-text-center">
                    <div class="tw-text-6xl tw-mb-4">🧩</div>
                    <h2 data-board-target="enigmaTitle" class="tw-text-2xl tw-font-bold tw-text-blue-700 tw-mb-2">Titre Enigme</h2>
                    <div class="tw-mb-4">
                        <span data-board-target="enigmaType" class="tw-inline-block tw-bg-blue-100 tw-text-blue-800 tw-text-xs tw-px-2 tw-py-1 tw-rounded-full tw-uppercase tw-tracking-wide tw-font-semibold">Type</span>
                    </div>
                    
                    <div class="tw-bg-blue-50 tw-p-6 tw-rounded-lg tw-border tw-border-blue-200 tw-mb-6 tw-text-left">
                        <h4 class="tw-text-sm tw-font-bold tw-text-blue-800 tw-mb-2 tw-uppercase">Consigne :</h4>
                        <p data-board-target="enigmaDesc" class="tw-text-gray-700 tw-italic tw-mb-4">Description...</p>
                        
                        <div data-board-target="enigmaVignetteContainer" class="tw-hidden tw-mt-4 tw-pt-4 tw-border-t tw-border-blue-200">
                            <h4 class="tw-text-sm tw-font-bold tw-text-blue-800 tw-mb-1 tw-uppercase">Info Vignette :</h4>
                            <p data-board-target="enigmaVignette" class="tw-text-sm tw-text-gray-600">Info...</p>
                        </div>
                    </div>
                    
                    <a data-board-target="enigmaLink" href="#" class="tw-inline-block tw-px-8 tw-py-3 tw-bg-blue-600 hover:tw-bg-blue-700 tw-text-white tw-font-bold tw-rounded-full tw-shadow-lg tw-transition-transform hover:tw-scale-105">
                        ACCÉDER À L'ÉNIGME
                    </a>
                </div>
            </div>
        </div>

        {% if jeu and jeu.messageDeBienvenue %}
            <div class="tw-bg-blue-100 tw-border-l-4 tw-border-blue-500 tw-text-blue-700 tw-p-4 tw-mb-8 tw-rounded tw-shadow-sm" role="alert">
                <p class="tw-font-bold">Message de bienvenue :</p>
                <p>{{ jeu.messageDeBienvenue }}</p>
            </div>
        {% endif %}


        {% if timerSeconds > 0 %}
    <div class="tw-mb-6 tw-flex tw-justify-center">
        <div class="tw-inline-flex tw-items-center tw-gap-3 tw-rounded-lg tw-border tw-border-amber-300 tw-bg-amber-50 tw-px-4 tw-py-2 tw-shadow-sm">
            <span class="tw-font-semibold tw-text-amber-900">Temps restant</span>
            <span data-board-target="timer" class="tw-text-2xl tw-font-bold tw-tabular-nums tw-text-amber-900">00:00</span>
        </div>
    </div>
{% endif %}
        <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 lg:tw-grid-cols-3 tw-gap-8 tw-justify-items-center">
            {% for enigme in enigmes %}
                <div class="tw-w-64 tw-flex tw-flex-col tw-gap-3">
                    <div class="tw-h-96 tw-cursor-pointer tw-transition-transform hover:tw-scale-105 {% if not enigme.active %}tw-opacity-70{% endif %}"
                         data-action="click->board#openEnigma"
                         data-board-title-param="{{ enigme.titre }}"
                         data-board-desc-param="{{ enigme.consigne|slice(0, 150) }}..."
                         data-board-type-param="{{ enigme.type.libelle }}"
                         data-board-vignette-param="{% if enigme.vignette %}{{ enigme.vignette.information }}{% endif %}"
                         data-board-url-param="{{ path('app_enigme_show', {'id': enigme.id}) }}"
                         data-board-index-param="{{ loop.index }}">
                    <div class="tw-w-full tw-h-full tw-rounded-xl tw-overflow-hidden tw-border-4 {% if enigme.active %}tw-border-blue-500{% else %}tw-border-gray-400{% endif %} tw-bg-white tw-flex tw-flex-col tw-items-center tw-justify-center tw-p-4 tw-shadow-xl">
                        <h3 class="tw-text-xl tw-font-bold tw-text-blue-600 tw-text-center">Énigme {{ loop.index }}</h3>
                        <p class="tw-mt-2 tw-text-sm tw-text-gray-500 tw-text-center">{{ enigme.titre }}</p>
                        <span class="tw-mt-2 tw-inline-block tw-bg-blue-100 tw-text-blue-800 tw-text-xs tw-px-2 tw-py-1 tw-rounded-full">{{ enigme.type.libelle }}</span>
                    <br>
                        {% if canManageEnigmes %}
                        <form method="post" action="{{ path('app_enigme_toggle_active', {'id': enigme.id}) }}" class="tw-flex tw-justify-center" onclick="event.stopPropagation();">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_active' ~ enigme.id) }}">
                            <button
                                type="submit"
                                onclick="event.stopPropagation();"
                                class="tw-inline-flex tw-items-center tw-gap-2 tw-text-xs tw-font-semibold tw-px-3 tw-py-2 tw-rounded-full tw-border {% if enigme.active %}tw-border-red-300 tw-bg-red-50 tw-text-red-700 hover:tw-bg-red-100{% else %}tw-border-green-300 tw-bg-green-50 tw-text-green-700 hover:tw-bg-green-100{% endif %}"
                                title="{{ enigme.active ? 'Désactiver' : 'Activer' }}"
                            >
                                <i class="bi {{ enigme.active ? 'bi-toggle-on' : 'bi-toggle-off' }}"></i>
                                {{ enigme.active ? 'Désactiver' : 'Activer' }}
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>

                </div>
            {% endfor %}
        </div>

        <div class="tw-mt-12 tw-max-w-2xl tw-mx-auto">
            <div class="tw-bg-gray-900 tw-rounded-xl tw-overflow-hidden tw-border-4 tw-border-yellow-500 tw-shadow-2xl">
                <div class="tw-bg-yellow-500 tw-py-3 tw-px-6 tw-flex tw-justify-between tw-items-center">
                    <h3 class="tw-text-xl tw-font-bold tw-text-gray-900 tw-uppercase tw-tracking-wider"><i class="tw-text-2xl tw-mr-2">🔐</i> Verrou Final</h3>
                    <span class="tw-text-gray-900 tw-font-semibold tw-text-sm">Trouvez pour gagner</span>
                </div>
                <div class="tw-p-8 tw-flex tw-flex-col md:tw-flex-row tw-items-center tw-gap-4">
                    <div class="tw-flex-1 tw-w-full">
                        <label for="finalCode" class="tw-block tw-text-yellow-400 tw-text-sm tw-font-bold tw-mb-2">Saisir le Code final</label>
                        <input type="text" 
                                id="finalCode"
                                data-board-target="finalCodeInput"
                                class="tw-w-full tw-px-4 tw-py-3 tw-bg-gray-800 tw-border-2 tw-border-gray-600 tw-rounded tw-text-white tw-text-center tw-text-xl tw-tracking-[0.2em] tw-uppercase tw-placeholder-gray-500 focus:tw-outline-none focus:tw-border-yellow-400 focus:tw-ring-1 focus:tw-ring-yellow-400 transition-colors"
                                placeholder="VOTRE CODE"
                                maxlength="20">
                    </div>
                    <div class="tw-w-full md:tw-w-auto tw-flex tw-flex-col">
                        <button type="button"
                                data-action="click->board#checkFinalCode"
                                class="tw-w-full tw-mt-6 md:tw-mt-6 tw-px-8 tw-py-3 tw-bg-yellow-500 hover:tw-bg-yellow-400 tw-text-gray-900 tw-font-bold tw-text-lg tw-rounded tw-transition-colors tw-shadow-lg transform active:tw-scale-95">
                            DÉVERROUILLER
                        </button>
                    </div>
                </div>
                <div data-board-target="finalMessage" class="tw-text-center tw-pb-6 tw-min-h-[40px] tw-text-lg"></div>
            </div>
        </div>
    </div>

    <style>
        .tw-perspective-1000 {
            perspective: 1000px;
        }
        .tw-transform-style-3d {
            transform-style: preserve-3d;
        }
        .tw-backface-hidden {
            backface-visibility: hidden;
        }
        .tw-rotate-y-180 {
            transform: rotateY(180deg);
        }
    </style>
{% endblock %}
