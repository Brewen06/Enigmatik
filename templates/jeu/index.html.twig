{% extends 'base.html.twig' %}

{% block title %}Enigmatik - Jeu{% endblock %}

{% block body %}
    <div class="tw-text-center tw-mb-10">
        <h1 class="tw-text-4xl tw-font-bold tw-mb-2">Bienvenue <span class="tw-text-blue-600">{% if equipe %}{{ equipe.nom }}{% endif %}</span> !</h1>
        <p class="tw-text-lg tw-text-gray-600">Prêt à relever le défi ? Résolvez les énigmes pour avancer.</p>
    </div>

    <div class="tw-container tw-mx-auto tw-px-4">
        <h2 class="tw-text-2xl tw-font-bold tw-mb-8 tw-text-center tw-border-b tw-pb-4">Les Énigmes</h2>
        
        <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 lg:tw-grid-cols-3 tw-gap-6">
            {% for enigme in enigmes %}
                <div class="card tw-h-full tw-shadow-md hover:tw-shadow-xl tw-transition tw-duration-300 tw-border-0">
                    <div class="card-body tw-flex tw-flex-col">
                        <h3 class="card-title tw-text-xl tw-font-bold tw-mb-3">{{ enigme.titre }}</h3>
                        <p class="card-text tw-text-gray-600 tw-flex-grow">{{ enigme.consigne|slice(0, 100) }}...</p>
                        <div class="tw-mt-4 tw-text-right">
                            <a href="{{ path('app_enigme_show', {'id': enigme.id}) }}" class="btn btn-primary">
                                🧩 Voir l'énigme
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="tw-col-span-full tw-text-center tw-p-10 tw-bg-gray-50 tw-rounded-lg">
                    <p class="tw-text-gray-500 tw-text-lg">Aucune énigme disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
