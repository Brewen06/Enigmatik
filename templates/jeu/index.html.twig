{% extends 'base.html.twig' %}

{% block title %}Enigmatik{% endblock %}

{% block body %}
    <h1>Bienvenue <strong>{% if equipe %}{{ equipe.nom }}{% endif %}</strong> dans Enigmatik !</h1>

    <p>Vous êtes ici pour découvrir les bases de l'informatique à travers des énigmes ludiques.</p>

    <div class="container mx-auto mt-10 px-4">
        <h2 class="text-2xl font-bold mb-6 text-center">Voici les énigmes proposées</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for enigme in enigmes %}
                <div class="bg-white rounded-lg shadow-md p-6 border">
                    <h3 class="text-xl font-bold mb-2">{{ enigme.titre }}</h3>
                    <p class="text-gray-700 mb-4">{{ enigme.consigne }}</p>
                    <a href="{{ path('app_enigme_show', {'id': enigme.id}) }}" class="text-blue-500 hover:underline">Voir l'énigme</a>
                </div>
            {% else %}
                <p class="text-center col-span-full text-gray-500">Aucune énigmes disponible pour le moment.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
