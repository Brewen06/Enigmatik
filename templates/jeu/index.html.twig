{% extends 'base.html.twig' %}

{% block title %}Enigmatik - Jeu{% endblock %}

{% block body %}
    <section class="welcome-note tw-mb-10 tw-relative">
        <div class="welcome-note__tape welcome-note__tape--left" aria-hidden="true"></div>
        <div class="welcome-note__tape welcome-note__tape--right" aria-hidden="true"></div>
        <div class="welcome-note__body tw-text-center tw-px-4 tw-py-7">
            <h1 class="welcome-note__title tw-mb-2">Bienvenue <span class="welcome-note__team">{% if equipe %}{{ equipe.nom }}{% endif %}</span></h1>
            <p class="welcome-note__subtitle tw-mb-0">Explorez le mur d'énigmes, débloquez les indices et assemblez le code final.</p>
        </div>
    </section>

    {% if equipe %}
        <div class="team-note tw-max-w-xl tw-mx-auto tw-p-4 tw-mb-8 tw-flex tw-items-center tw-gap-4 tw-relative">
            <div class="team-note__pin" aria-hidden="true"></div>
            {% if equipe.avatar %}
                <img src="{{ asset(equipe.avatar.image) }}" alt="{{ equipe.avatar.nom }}" class="team-note__avatar tw-w-16 tw-h-16 tw-rounded-full tw-object-cover">
            {% endif %}
            <div>
                <p class="team-note__label tw-mb-1">Données de l'équipe</p>
                <p class="team-note__name tw-mb-0">{{ equipe.nom }}</p>
                {% if equipe.avatar %}
                    <p class="team-note__meta tw-mb-0">Avatar : {{ equipe.avatar.nom }}</p>
                {% endif %}
            </div>
        </div>

        <section class="clue-note tw-max-w-3xl tw-mx-auto tw-mb-8">
            <div class="clue-note__pin" aria-hidden="true"></div>
            <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-mb-3">
                <h2 class="clue-note__title tw-mb-0">Indices récupérés</h2>
                <span class="clue-note__counter">{{ recoveredHints|length }} trouvé(s)</span>
            </div>

            {% if recoveredHints is not empty %}
                <ul class="tw-list-none tw-p-0 tw-m-0 clue-note__list">
                    {% for hint in recoveredHints %}
                        <li class="clue-note__item">
                            <p class="clue-note__meta tw-mb-1">Énigme {{ hint.ordre }}{% if hint.titre %} - {{ hint.titre }}{% endif %}</p>
                            <p class="clue-note__value tw-mb-0">{{ hint.indice }}</p>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="tw-mb-0 clue-note__empty">Aucun indice récupéré pour le moment. Résolvez une énigme pour débloquer votre premier indice.</p>
            {% endif %}
        </section>
    {% endif %}

    <div class="tw-container tw-relative tw-mx-auto tw-px-4" 
         data-controller="board" 
         data-board-validate-url-value="{{ path('app_jeu_validate_final_code') }}"
         data-board-victory-url-value="{{ path('app_jeu_victoire') }}"
         data-board-team-id-value="{{ equipe ? equipe.id : 0 }}"
            data-board-timer-seconds-value="{{ timerSeconds }}"
            data-board-timer-locked-value="{{ timerLocked ? 'true' : 'false' }}">
        <div data-board-target="modal" class="tw-hidden tw-fixed tw-inset-0 tw-z-50 tw-flex tw-items-center tw-justify-center tw-p-4 tw-bg-black tw-bg-opacity-75 tw-backdrop-blur-sm tw-overflow-y-auto">
            <div class="intro-brief tw-max-w-2xl tw-w-full tw-my-4 tw-relative">
                <div class="intro-brief__tape intro-brief__tape--left" aria-hidden="true"></div>
                <div class="intro-brief__tape intro-brief__tape--right" aria-hidden="true"></div>
                <button data-action="click->board#closeModal" class="intro-brief__close" aria-label="Fermer le message de bienvenue">
                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-h-8 tw-w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                {% if jeu and jeu.messageDeBienvenue %}
                    <h2 class="intro-brief__title">Débriefing de mission</h2>
                    <p class="intro-brief__lead">Lisez les consignes avant d'ouvrir le mur.</p>
                    <p class="intro-brief__content tw-whitespace-pre-line">{{ jeu.messageDeBienvenue }}</p>
                    <button data-action="click->board#closeModal" class="intro-brief__cta tw-mt-6">
                        Accéder au jeu
                    </button>
                {% else %}
                    <h2 class="intro-brief__title">Bienvenue à votre mission !</h2>
                    <p class="intro-brief__lead">Votre dossier est prêt.</p>
                    <p class="intro-brief__content">Résolvez les énigmes dans l'ordre, récupérez les indices et déverrouillez le code final.</p>
                    <button data-action="click->board#closeModal" class="intro-brief__cta tw-mt-6">
                        Accéder au jeu
                    </button>
                {% endif %}
            </div>
        </div>

        <div data-board-target="enigmaModal" class="tw-hidden tw-fixed tw-inset-0 tw-z-50 tw-flex tw-items-center tw-justify-center tw-p-4 tw-bg-black tw-bg-opacity-75 tw-backdrop-blur-sm tw-overflow-y-auto">
            <div class="tw-bg-white tw-rounded-xl tw-p-8 tw-max-w-lg tw-w-full tw-relative tw-shadow-2xl tw-border-4 tw-border-blue-500">
                <button data-action="click->board#closeEnigmaModal" class="tw-absolute tw-top-4 tw-right-4 tw-text-gray-400 hover:tw-text-gray-800 tw-transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="tw-h-8 tw-w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
                
                <div class="tw-text-center">
                    <h2 data-board-target="enigmaTitle" class="tw-text-2xl tw-font-bold tw-text-blue-700 tw-mb-2">Titre Enigme</h2>
                    <div class="tw-mb-4">
                        <span data-board-target="enigmaType" class="tw-inline-block tw-bg-blue-100 tw-text-blue-800 tw-text-xs tw-px-2 tw-py-1 tw-rounded-full tw-uppercase tw-tracking-wide tw-font-semibold">Type</span>
                    </div>
                    
                    <div class="tw-bg-blue-50 tw-p-6 tw-rounded-lg tw-border tw-border-blue-200 tw-mb-6 tw-text-left">
                        <h4 class="tw-text-sm tw-font-bold tw-text-blue-800 tw-mb-2 tw-uppercase">Consigne :</h4>
                        <p data-board-target="enigmaDesc" class="tw-text-gray-700 tw-italic tw-mb-4">Description...</p>
                        
                        <div data-board-target="enigmaVignetteContainer" class="tw-hidden tw-mt-4 tw-pt-4 tw-border-t tw-border-blue-200">
                            <h4 class="tw-text-sm tw-font-bold tw-text-blue-800 tw-mb-1 tw-uppercase">Info Vignette :</h4>
                            <p data-board-target="enigmaVignette" class="tw-text-sm tw-text-gray-600">Info...</p>
                        </div>
                    </div>
                    
                    <a data-board-target="enigmaLink" href="#" class="tw-inline-block tw-px-8 tw-py-3 tw-bg-blue-600 hover:tw-bg-blue-700 tw-text-white tw-font-bold tw-rounded-full tw-shadow-lg tw-transition-transform hover:tw-scale-105">
                        ACCÉDER À L'ÉNIGME
                    </a>
                </div>
            </div>
        </div>


        {% if timerSeconds > 0 %}
            <div class="timer-note-wrap tw-mb-6 tw-flex tw-justify-center">
                <div class="timer-note tw-inline-flex tw-items-center tw-gap-3 tw-px-4 tw-py-2 tw-relative">
                    <div class="timer-note__pin" aria-hidden="true"></div>
                    <i class="bi bi-stopwatch-fill timer-note__icon" aria-hidden="true"></i>
                    <span class="timer-note__label">Temps restant</span>
                    <span data-board-target="timer" class="timer-note__value tw-tabular-nums">00:00</span>
                </div>
            </div>
        {% endif %}
        <section class="enigma-wall tw-rounded-2xl tw-p-4 md:tw-p-6 tw-shadow-2xl">
        <div class="tw-flex tw-items-center tw-justify-between tw-gap-4 tw-mb-5 tw-px-1">
            <h2 class="tw-text-xl tw-font-bold tw-uppercase tw-tracking-wide tw-text-amber-100 tw-mb-0">Mur d'énigmes</h2>
            <span class="tw-text-xs tw-font-semibold tw-uppercase tw-text-amber-200 tw-bg-black/20 tw-px-3 tw-py-1 tw-rounded-full">{{ enigmes|length }} dossiers</span>
        </div>

        <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 lg:tw-grid-cols-3 tw-gap-6 tw-justify-items-stretch">
            {% for enigme in enigmes %}
                {% set isUnlocked = canManageEnigmes or loop.index <= unlockedEnigmeCount %}
                {% if isUnlocked %}
                {% set isSolved = enigme.id in resolvedEnigmeIds %}
                <div class="tw-flex tw-flex-col tw-gap-3">
                    <article class="enigma-file tw-cursor-pointer tw-transition-transform hover:tw-scale-[1.02] {% if not enigme.active %}tw-opacity-75{% endif %}"
                         data-action="click->board#openEnigma"
                         data-board-title-param="{{ enigme.titre }}"
                         data-board-desc-param="{{ enigme.consigne|slice(0, 150) }}..."
                         data-board-type-param="{{ enigme.type.libelle }}"
                         data-board-vignette-param="{% if enigme.vignette %}{{ enigme.vignette.information }}{% endif %}"
                         data-board-url-param="{{ path('app_enigme_show', {'id': enigme.id}) }}"
                         data-board-index-param="{{ loop.index }}">
                    <div class="enigma-file__tape enigma-file__tape--left" aria-hidden="true"></div>
                    <div class="enigma-file__tape enigma-file__tape--right" aria-hidden="true"></div>
                    <div class="enigma-file__body {% if enigme.active %}enigma-file__body--active{% else %}enigma-file__body--inactive{% endif %} {% if isSolved %}enigma-file__body--solved{% endif %}">
                        <p class="enigma-file__tag tw-mb-2">Dossier #{{ enigme.ordre }}</p>
                        <h3 class="enigma-file__title">{{ enigme.titre }}</h3>
                        <p class="enigma-file__excerpt">{{ enigme.consigne|slice(0, 95) }}{% if enigme.consigne|length > 95 %}...{% endif %}</p>
                        <div class="tw-flex tw-items-center tw-justify-between tw-gap-2 tw-mt-auto">
                            <span class="enigma-file__type">{{ enigme.type.libelle }}</span>
                            <span class="enigma-file__state {% if isSolved %}enigma-file__state--solved{% elseif enigme.active %}enigma-file__state--on{% else %}enigma-file__state--off{% endif %}">
                                {% if isSolved %}
                                    Résolue
                                {% else %}
                                    {{ enigme.active ? 'Active' : 'Inactive' }}
                                {% endif %}
                            </span>
                        </div>

                        {% if canManageEnigmes %}
                        <form method="post" action="{{ path('app_enigme_toggle_active', {'id': enigme.id}) }}" class="tw-flex tw-justify-center tw-mt-3" onclick="event.stopPropagation();">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_active' ~ enigme.id) }}">
                            <button
                                type="submit"
                                onclick="event.stopPropagation();"
                                class="tw-inline-flex tw-items-center tw-gap-2 tw-text-xs tw-font-semibold tw-px-3 tw-py-2 tw-rounded-full tw-border {% if enigme.active %}tw-border-red-300 tw-bg-red-50 tw-text-red-700 hover:tw-bg-red-100{% else %}tw-border-green-300 tw-bg-green-50 tw-text-green-700 hover:tw-bg-green-100{% endif %}"
                                title="{{ enigme.active ? 'Désactiver' : 'Activer' }}"
                            >
                                <i class="bi {{ enigme.active ? 'bi-toggle-on' : 'bi-toggle-off' }}"></i>
                                {{ enigme.active ? 'Désactiver' : 'Activer' }}
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </article>
                </div>
                {% endif %}
            {% endfor %}
        </div>
        </section>

        <section class="final-lock tw-mt-12 tw-max-w-3xl tw-mx-auto">

            <div class="final-lock__panel">
                <div class="final-lock__header tw-flex tw-justify-between tw-items-center tw-gap-3">
                    <h3 class="final-lock__title tw-mb-0"><i class="tw-text-xl tw-mr-2">🔐</i> Verrou final</h3>
                    <span class="final-lock__subtitle">Assemblez vos indices</span>
                </div>

                <div class="tw-p-6 md:tw-p-8 tw-flex tw-flex-col md:tw-flex-row tw-items-center tw-gap-4">
                    <div class="tw-flex-1 tw-w-full">
                        <label for="finalCode" class="final-lock__label">Saisir le code final</label>
                        <input type="text" 
                                id="finalCode"
                                data-board-target="finalCodeInput"
                                class="final-lock__input tw-w-full tw-px-4 tw-py-3 tw-text-center tw-text-xl tw-tracking-[0.2em] tw-uppercase"
                                placeholder="VOTRE CODE"
                                maxlength="20">
                    </div>
                    <div class="tw-w-full md:tw-w-auto tw-flex tw-flex-col">
                        <button type="button"
                                data-action="click->board#checkFinalCode"
                                class="final-lock__button tw-w-full tw-mt-6 md:tw-mt-6 tw-px-8 tw-py-3 tw-font-bold tw-text-lg tw-rounded tw-transition-colors tw-shadow-lg transform active:tw-scale-95">
                            DÉVERROUILLER
                        </button>
                    </div>
                </div>

                <div data-board-target="finalMessage" class="final-lock__message tw-text-center tw-pb-6 tw-min-h-[40px] tw-text-lg"></div>
            </div>
        </section>
    </div>

    <style>
        .welcome-note {
            max-width: 72rem;
            margin-left: auto;
            margin-right: auto;
        }

        .welcome-note__body {
            background:
                linear-gradient(to bottom, rgba(72, 130, 215, 0.12) 1px, transparent 1px),
                linear-gradient(90deg, rgba(214, 84, 84, 0.18) 0, rgba(214, 84, 84, 0.18) 1px, transparent 1px),
                #fffef2;
            background-size: 100% 2rem, 2.5rem 100%, auto;
            background-position: 0 2.9rem, 2.4rem 0, 0 0;
            border: 1px solid #e2d7b8;
            border-radius: 0.55rem;
            box-shadow: 0 18px 30px rgba(31, 23, 11, 0.2);
            transform: rotate(-0.45deg);
        }

        .welcome-note__tape {
            position: absolute;
            top: -0.5rem;
            width: 5rem;
            height: 1.1rem;
            background: rgba(234, 225, 192, 0.62);
            border: 1px solid rgba(148, 128, 70, 0.26);
            z-index: 2;
            transform: rotate(-10deg);
            backdrop-filter: blur(1px);
        }

        .welcome-note__tape--left {
            left: 2rem;
        }

        .welcome-note__tape--right {
            right: 2rem;
            transform: rotate(11deg);
        }

        .welcome-note__kicker {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.11em;
            color: #746749;
        }

        .welcome-note__title {
            font-size: clamp(1.95rem, 1.45rem + 1.25vw, 3rem);
            font-weight: 800;
            color: #3a3528;
            line-height: 1.1;
        }

        .welcome-note__team {
            color: #2b65d9;
        }

        .welcome-note__subtitle {
            font-size: clamp(1rem, 0.9rem + 0.45vw, 1.7rem);
            color: #51493c;
        }

        .team-note {
            background: linear-gradient(180deg, #fffdf6 0%, #f4ecd9 100%);
            border: 1px solid #dccda9;
            border-radius: 0.8rem;
            box-shadow: 0 14px 24px rgba(31, 22, 10, 0.2);
            transform: rotate(-0.35deg);
        }

        .team-note__pin {
            position: absolute;
            top: -0.42rem;
            right: 1.1rem;
            width: 0.95rem;
            height: 0.95rem;
            border-radius: 999px;
            background: radial-gradient(circle at 35% 30%, #ffffff 0%, #ccd4df 40%, #7f8ca1 100%);
            box-shadow: 0 3px 5px rgba(0, 0, 0, 0.25);
        }

        .team-note__avatar {
            border: 3px solid #f8f1de;
            box-shadow: 0 5px 10px rgba(31, 23, 11, 0.2);
            background: #fff;
        }

        .team-note__label {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #70644a;
        }

        .team-note__name {
            font-size: 1.85rem;
            line-height: 1;
            font-weight: 800;
            color: #2e2a21;
        }

        .team-note__meta {
            font-size: 0.95rem;
            color: #5f584b;
        }

        .timer-note {
            background:
                linear-gradient(to bottom, rgba(68, 121, 204, 0.12) 1px, transparent 1px),
                linear-gradient(90deg, rgba(210, 87, 77, 0.17) 0, rgba(210, 87, 77, 0.17) 1px, transparent 1px),
                #fffef2;
            background-size: 100% 1.7rem, 1.75rem 100%, auto;
            background-position: 0 2rem, 1.1rem 0, 0 0;
            border: 1px solid #e0d5b7;
            border-radius: 0.35rem;
            box-shadow: 0 12px 22px rgba(31, 23, 11, 0.2);
            transform: rotate(0.5deg);
        }

        .timer-note__pin {
            position: absolute;
            top: -0.38rem;
            left: 1rem;
            width: 0.85rem;
            height: 0.85rem;
            border-radius: 999px;
            background: radial-gradient(circle at 35% 30%, #ffffff 0%, #ccd4df 40%, #7f8ca1 100%);
            box-shadow: 0 3px 5px rgba(0, 0, 0, 0.25);
        }

        .timer-note__icon {
            font-size: 1.15rem;
            color: #6f5827;
        }

        .timer-note__label {
            font-size: 0.76rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
            color: #6d6047;
        }

        .timer-note__value {
            font-size: 1.42rem;
            font-weight: 900;
            letter-spacing: 0.07em;
            color: #2f2a1f;
            min-width: 5.2rem;
            text-align: center;
        }

        .clue-note {
            position: relative;
            background:
                linear-gradient(to bottom, rgba(72, 130, 215, 0.12) 1px, transparent 1px),
                linear-gradient(90deg, rgba(214, 84, 84, 0.18) 0, rgba(214, 84, 84, 0.18) 1px, transparent 1px),
                #fffef2;
            background-size: 100% 1.9rem, 2.2rem 100%, auto;
            background-position: 0 2.8rem, 2rem 0, 0 0;
            border: 1px solid #e7ddbb;
            border-radius: 0.4rem;
            box-shadow: 0 18px 28px rgba(35, 28, 17, 0.2);
            padding: 1.2rem 1.1rem 1rem 3rem;
            transform: rotate(-0.6deg);
        }

        .clue-note__pin {
            position: absolute;
            width: 1rem;
            height: 1rem;
            border-radius: 999px;
            top: -0.45rem;
            left: 1.35rem;
            background: radial-gradient(circle at 35% 30%, #ffffff 0%, #c9ced8 35%, #7a8498 100%);
            box-shadow: 0 3px 6px rgba(0, 0, 0, 0.28);
        }

        .clue-note__title {
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #2f3d4b;
        }

        .clue-note__counter {
            font-size: 0.74rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #5c6370;
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid #dbd5bd;
            border-radius: 999px;
            padding: 0.2rem 0.6rem;
        }

        .clue-note__list {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.5rem;
        }

        .clue-note__item {
            border-bottom: 1px dashed rgba(58, 79, 115, 0.26);
            padding-bottom: 0.35rem;
        }

        .clue-note__item:last-child {
            border-bottom: 0;
            padding-bottom: 0;
        }

        .clue-note__meta {
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #5a6270;
        }

        .clue-note__value {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #1b3354;
        }

        .clue-note__empty {
            color: #5b6472;
            font-style: italic;
        }

        .enigma-wall {
            background:
                linear-gradient(145deg, rgba(124, 70, 42, 0.72), rgba(102, 57, 35, 0.88)),
                repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.04) 0 2px, transparent 2px 18px),
                repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.06) 0 2px, transparent 2px 24px);
            border: 1px solid rgba(70, 34, 18, 0.55);
        }

        .enigma-file {
            position: relative;
            min-height: 18rem;
        }

        .enigma-file__tape {
            position: absolute;
            width: 4.2rem;
            height: 1.05rem;
            top: -0.35rem;
            background: rgba(237, 228, 189, 0.56);
            border: 1px solid rgba(148, 128, 70, 0.28);
            z-index: 2;
            transform: rotate(-8deg);
            backdrop-filter: blur(1px);
        }

        .enigma-file__tape--left {
            left: 1rem;
        }

        .enigma-file__tape--right {
            right: 1rem;
            transform: rotate(9deg);
        }

        .enigma-file__body {
            position: relative;
            z-index: 1;
            min-height: 18rem;
            border-radius: 0.8rem;
            border: 1px solid #d8d0b5;
            background: linear-gradient(180deg, #fffef8, #f8f3e7);
            padding: 1rem;
            box-shadow: 0 10px 22px rgba(30, 19, 11, 0.28);
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
        }

        .enigma-file__body--active {
            outline: 3px solid rgba(53, 124, 231, 0.5);
        }

        .enigma-file__body--inactive {
            filter: grayscale(0.15);
            outline: 3px solid rgba(107, 114, 128, 0.45);
        }

        .enigma-file__tag {
            display: inline-block;
            align-self: flex-start;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: #193054;
            background: #cfe2ff;
            border-radius: 999px;
            padding: 0.2rem 0.55rem;
        }

        .enigma-file__title {
            font-size: 1.18rem;
            font-weight: 800;
            color: #2c2a24;
            margin: 0;
        }

        .enigma-file__excerpt {
            font-size: 0.92rem;
            color: #5d5648;
            margin: 0.2rem 0 0;
            line-height: 1.4;
        }

        .enigma-file__type {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            background: #efe4c8;
            color: #66542b;
            border-radius: 999px;
            padding: 0.2rem 0.55rem;
            font-weight: 700;
        }

        .enigma-file__state {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            border-radius: 999px;
            padding: 0.2rem 0.5rem;
            font-weight: 800;
