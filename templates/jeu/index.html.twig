{% extends 'base.html.twig' %}

{% block title %}Jeu index{% endblock %}

{% block body %}
    <h1>Jeu index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>MessageDeBienvenue</th>
                <th>ImageBienvenue</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for jeu in jeus %}
            <tr>
                <td>{{ jeu.id }}</td>
                <td>{{ jeu.titre }}</td>
                <td>{{ jeu.messageDeBienvenue }}</td>
                <td>{{ jeu.imageBienvenue }}</td>
                <td>
                    <a href="{{ path('app_jeu_show', {'id': jeu.id}) }}">show</a>
                    <a href="{{ path('app_jeu_edit', {'id': jeu.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="container mx-auto mt-10 px-4">
        <h2 class="text-2xl font-bold mb-6 text-center">Nos Jeux</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for jeu in jeux %}
                <div class="bg-white rounded-lg shadow-md p-6 border">
                    <h3 class="text-xl font-bold mb-2">{{ jeu.titre }}</h3>
                    <p class="text-gray-700 mb-4">{{ jeu.messageDeBienvenue }}</p>
                    <a href="{{ path('app_jeu_show', {'id': jeu.id}) }}" class="text-blue-500 hover:underline">Voir le jeu</a>
                </div>
            {% else %}
                <p class="text-center col-span-full text-gray-500">Aucun jeu disponible pour le moment.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
