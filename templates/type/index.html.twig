{% extends 'base.html.twig' %}

{% block title %}Liste des types{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h1 class="h3 mb-0 text-white">Liste des types</h1>
        <a href="{{ path('app_type_new') }}" class="btn btn-light btn-sm">
            <i class="bi bi-plus-lg"></i> Créer un type
        </a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Libellé</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for type in types %}
                    <tr>
                        <td>{{ type.id }}</td>
                        <td>{{ type.libelle }}</td>
                        <td class="text-end">
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_type_show', {'id': type.id}) }}" class="btn btn-info btn-sm text-white" title="Voir">
                                    Voir
                                </a>
                                <a href="{{ path('app_type_edit', {'id': type.id}) }}" class="btn btn-warning btn-sm text-white" title="Modifier">
                                    Modifier
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center py-4">Aucun type trouvé</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
