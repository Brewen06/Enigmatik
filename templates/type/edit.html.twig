{% extends 'base.html.twig' %}

{% block title %}Modifier le type{% endblock %}

{% block body %}
<section class="enigme-page">
    <div class="enigme-page__card">
        <div class="enigme-page__header">
            <h1 class="enigme-page__title">Modifier le type</h1>
            <p class="enigme-page__subtitle">Mettez à jour le type de jeu en conservant la cohérence.</p>
        </div>

        {{ include('type/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <div class="enigme-page__actions mt-4 d-flex flex-wrap gap-2">
            <a href="{{ path('app_type_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
            {{ include('type/_delete_form.html.twig') }}
        </div>
    </div>
</section>
{% endblock %}
