{% extends 'base.html.twig' %}

{% block title %}Nouvelle vignette{% endblock %}

{% block body %}
<section class="enigme-page">
    <div class="enigme-page__card">
        <div class="enigme-page__header">
            <h1 class="enigme-page__title">Créer une nouvelle vignette</h1>
            <p class="enigme-page__subtitle">Ajoutez un visuel pour illustrer les differentes enigmes.</p>
        </div>

        {{ include('vignette/_form.html.twig') }}

        <div class="enigme-page__actions mt-4 d-flex flex-wrap gap-2">
            <a href="{{ path('app_vignette_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
        </div>
    </div>
</section>
{% endblock %}
