{% extends 'base.html.twig' %}

{% block title %}Edit Equipe{% endblock %}

{% block body %}
<section class="edit-page">
    <div class="edit-page__card">
        <div class="edit-page__header">
            <h1 class="edit-page__title">Modifier l'équipe</h1>
            <p class="edit-page__subtitle">Modifiez les données de l'équipe et confirmez.</p>
        </div>

        {{ include('equipe/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        <div class="edit-page__actions mt-4 d-flex flex-wrap gap-2">
            <a href="{{ path('app_equipe_index') }}" class="btn btn-outline-secondary">Retour à la liste</a>
            {{ include('equipe/_delete_form.html.twig') }}
        </div>
    </div>
</section>
{% endblock %}
