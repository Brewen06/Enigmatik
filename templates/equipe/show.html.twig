{% extends 'base.html.twig' %}

{% block title %}Détails Équipe{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h1 class="h3 mb-0 text-white">Détails de l'équipe</h1>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th class="w-25 bg-light">Id</th>
                        <td>{{ equipe.id }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Nom</th>
                        <td>{{ equipe.nom }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Position</th>
                        <td>{{ equipe.position }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Note</th>
                        <td>{{ equipe.note }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Énigme Actuelle</th>
                        <td><span class="badge bg-primary">Niveau {{ equipe.enigmeActuelle }}</span></td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_equipe_index') }}" class="btn btn-secondary">
                    &larr; Retour à la liste
                </a>
                <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-warning text-white">
                    Modifier
                </a>
                {{ include('equipe/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
