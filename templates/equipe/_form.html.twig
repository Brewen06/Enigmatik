{{ form_start(form) }}
{{ form_row(form.nom) }}

<div class="mb-3">
    {{ form_label(form.avatar) }}
    {{ form_widget(form.avatar) }}
    {{ form_errors(form.avatar) }}

    <div id="avatar-preview-wrapper" class="mt-3 d-none">
        <p class="text-muted mb-2">Aperçu de l'avatar sélectionné</p>
        <img id="avatar-preview-image" src="" alt="Aperçu avatar" class="rounded-circle border" style="width: 80px; height: 80px; object-fit: cover;">
    </div>
</div>
{{ form_rest(form) }}

<div class="mt-4 text-center">
    <button class="btn btn-primary btn-lg px-5 rounded-pill shadow">{{ button_label|default('Enregistrer') }}</button>
</div>
{{ form_end(form) }}

<script>
    (() => {
        const select = document.getElementById('{{ form.avatar.vars.id }}');
        const previewWrapper = document.getElementById('avatar-preview-wrapper');
        const previewImage = document.getElementById('avatar-preview-image');
        const assetBase = '{{ asset('') }}';

        if (!select || !previewWrapper || !previewImage) {
            return;
        }

        const updatePreview = () => {
            const selectedOption = select.options[select.selectedIndex];
            const imagePath = selectedOption ? selectedOption.dataset.image : '';

            if (!imagePath) {
                previewWrapper.classList.add('d-none');
                previewImage.src = '';
                return;
            }

            const normalizedPath = imagePath.startsWith('/') ? imagePath.slice(1) : imagePath;
            previewImage.src = `${assetBase}${normalizedPath}`;
            previewWrapper.classList.remove('d-none');
        };

        select.addEventListener('change', updatePreview);
        updatePreview();
    })();
</script>