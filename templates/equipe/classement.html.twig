{% extends 'base.html.twig' %}

{% block title %}Classement des équipes{% endblock %}

{% block body %}
<div class="card shadow-lg border-0">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-trophy-fill me-2 text-warning"></i>Classement des équipes</h1>
        <a href="{{ path('app_equipe_index') }}" class="btn btn-light btn-sm fw-bold">
            <i class="bi bi-people-fill me-1"></i> Voir les équipes
        </a>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Équipe</th>
                        <th>Score</th>
                        <th>Progression</th>
                        <th>Temps</th>
                        <th class="pe-4">Énigmes résolues</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipe in equipes %}
                    <tr>
                        <td class="ps-4 fw-bold">
                            {% if equipe.rank == 1 %}
                                <span class="badge bg-warning text-dark">{{ equipe.rank }}</span>
                            {% elseif equipe.rank == 2 %}
                                <span class="badge bg-secondary">{{ equipe.rank }}</span>
                            {% elseif equipe.rank == 3 %}
                                <span class="badge" style="background-color: #b87333;">{{ equipe.rank }}</span>
                            {% else %}
                                <span class="badge bg-light text-dark border">{{ equipe.rank }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                {% if equipe.avatarImage %}
                                    <img src="{{ asset(equipe.avatarImage|replace({'public/': ''})) }}" alt="{{ equipe.avatarNom ?: 'Avatar' }}" class="rounded-circle" style="width: 38px; height: 38px; object-fit: cover;">
                                {% else %}
                                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 38px; height: 38px;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                {% endif %}
                                <div>
                                    <div class="fw-bold text-primary">{{ equipe.nom }}</div>
                                    {% if equipe.isFinished %}
                                        <span class="badge bg-success">Terminé</span>
                                    {% else %}
                                        <span class="badge bg-info text-dark">En cours</span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-primary">{{ equipe.solvedCount }}/{{ totalEnigmes }}</span>
                        </td>
                        <td style="min-width: 220px;">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Énigmes validées</span>
                                <span>{{ equipe.progressPercent }}%</span>
                            </div>
                            <div class="progress" role="progressbar" aria-label="Progression de {{ equipe.nom }}" aria-valuenow="{{ equipe.progressPercent }}" aria-valuemin="0" aria-valuemax="100" style="height: 10px;">
                                <div class="progress-bar bg-success js-progress-value" data-progress="{{ equipe.progressPercent }}"></div>
                            </div>
                            <div class="small text-muted mt-1">
                                {% if totalEnigmes == 0 %}
                                    Niveau actuel: aucune énigme
                                {% elseif equipe.isAllSolved %}
                                    Niveau actuel: terminé
                                {% else %}
                                    Niveau actuel: {{ equipe.enigmeActuelleDisplay }}
                                {% endif %}
                            </div>
                        </td>
                        <td>
                            {% if equipe.durationSeconds is not null %}
                                {% set hours = (equipe.durationSeconds / 3600)|round(0, 'floor') %}
                                {% set minutes = ((equipe.durationSeconds % 3600) / 60)|round(0, 'floor') %}
                                {% set seconds = (equipe.durationSeconds % 60)|round(0, 'floor') %}
                                <span class="badge bg-dark">
                                    {{ '%02d'|format(hours) }}:{{ '%02d'|format(minutes) }}:{{ '%02d'|format(seconds) }}
                                </span>
                            {% else %}
                                <span class="text-muted">-</span>
                            {% endif %}
                        </td>
                        <td class="pe-4" style="min-width: 260px;">
                            <div class="d-flex flex-wrap gap-1">
                                {% for enigme in equipe.enigmesProgression %}
                                    <span class="badge {{ enigme.resolved ? 'bg-success' : 'bg-light text-dark border' }}" title="Énigme {{ enigme.ordre }} - {{ enigme.titre }}">
                                        {{ enigme.ordre }}
                                    </span>
                                {% endfor %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Aucune équipe n'a encore commencé la partie.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.js-progress-value').forEach((element) => {
        const rawValue = Number.parseInt(element.dataset.progress || '0', 10);
        const safeValue = Number.isNaN(rawValue) ? 0 : Math.max(0, Math.min(rawValue, 100));
        element.style.width = safeValue + '%';
    });
</script>
{% endblock %}
