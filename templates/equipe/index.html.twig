{% extends 'base.html.twig' %}

{% block title %}Equipe index{% endblock %}

{% block body %}
    <h1>Equipe index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Position</th>
                <th>Note</th>
                <th>Enigme Actuelle</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for equipe in equipes %}
            <tr>
                <td>{{ equipe.id }}</td>
                <td>{{ equipe.nom }}</td>
                <td>{{ equipe.position }}</td>
                <td>{{ equipe.note }}</td>
                <td>{{ equipe.enigmeActuelle }}</td>
                <td>
                    <a href="{{ path('app_equipe_show', {'id': equipe.id}) }}">Show</a>
                    <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_equipe_créer') }}">Création d'une nouvelle équipe.</a>
{% endblock %}
