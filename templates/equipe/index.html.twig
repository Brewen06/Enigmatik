{% extends 'base.html.twig' %}

{% block title %}Liste des Équipes{% endblock %}

{% block body %}
<div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-trophy-fill me-2"></i>Liste des Équipes</h1>
        <a href="{{ path('app_equipe_creer') }}" class="btn btn-light btn-sm fw-bold text-primary">
            <i class="bi bi-plus-lg me-1"></i> Nouvelle Équipe
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Nom</th>
                        <th>Position</th>
                        <th>Note</th>
                        <th>Énigme Actuelle</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipe in equipes %}
                    <tr>
                        <td class="ps-4 text-muted">#{{ equipe.id }}</td>
                        <td class="fw-bold text-primary">{{ equipe.nom }}</td>
                        <td>
                            <span class="badge bg-secondary rounded-pill">{{ equipe.position }}</span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-star-fill text-warning me-1"></i>
                                {{ equipe.note }}
                            </div>
                        </td>
                        <td><span class="badge bg-info text-dark">Niveau {{ equipe.enigmeActuelle }}</span></td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_equipe_show', {'id': equipe.id}) }}" class="btn btn-outline-primary btn-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-outline-warning btn-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Aucune équipe inscrite pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
