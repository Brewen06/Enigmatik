{% block title %}Liste des Équipes{% endblock %}

{% block body %}
<div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-trophy-fill me-2"></i>Liste des équipes</h1>
        <div class="d-flex gap-2">
            {% if is_granted('ROLE_PROF') or is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_equipe_classement') }}" class="btn btn-warning btn-sm fw-bold">
                    <i class="bi bi-bar-chart-fill me-1"></i> Classement
                </a>
            {% endif %}
            <a href="{{ path('app_equipe_creer') }}" class="btn btn-light btn-sm fw-bold text-primary">
                <i class="bi bi-plus-lg me-1"></i> Nouvelle équipe
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Avatar</th>
                        <th>Nom</th>
                        <th>Position</th>
                        <th>Énigme Actuelle</th>
                        <th>Progression</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipe in equipes %}
                    <tr>
                        <td class="ps-4 text-muted">#{{ equipe.id }}</td>
                        <td>
                            {% if equipe.avatarImage %}
                                <img src="{{ asset(equipe.avatarImage|replace({'public/': ''})) }}" alt="{{ equipe.avatarNom ?: 'Avatar' }}" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                            {% else %}
                                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person"></i>
                                </div>
                            {% endif %}
                        </td>
                        <td class="fw-bold text-primary">{{ equipe.nom }}</td>
                        <td>
                            <span class="badge bg-secondary rounded-pill">{{ equipe.position }}</span>
                        </td>
                        <td>
                            {% if totalEnigmes == 0 %}
                                <span class="badge bg-secondary">Aucune énigme</span>
                            {% elseif equipe.isAllSolved %}
                                <span class="badge bg-success">Terminé</span>
                            {% else %}
                                <span class="badge bg-info text-dark">Niveau {{ equipe.enigmeActuelleDisplay }}</span>
                            {% endif %}
                        </td>
                        <td style="min-width: 240px;">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>{{ equipe.solvedCount }}/{{ totalEnigmes }} résolues</span>
                                <span>{{ equipe.progressPercent }}%</span>
                            </div>
                            <div class="progress" role="progressbar" aria-label="Progression de l'équipe {{ equipe.nom }}" aria-valuenow="{{ equipe.progressPercent }}" aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: {{ equipe.progressPercent }}%;"></div>
                            </div>
                            <div class="mt-2 d-flex flex-wrap gap-1">
                                {% for enigme in equipe.enigmesProgression %}
                                    <span class="badge {{ enigme.resolved ? 'bg-success' : 'bg-light text-dark border' }}" title="Énigme {{ enigme.ordre }} - {{ enigme.titre }}">
                                        {{ enigme.ordre }}
                                    </span>
                                {% endfor %}
                            </div>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_equipe_show', {'id': equipe.id}) }}" class="btn btn-outline-primary btn-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_equipe_edit', {'id': equipe.id}) }}" class="btn btn-outline-warning btn-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Aucune équipe inscrite pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
