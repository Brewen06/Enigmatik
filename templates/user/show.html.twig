{% extends 'base.html.twig' %}

{% block title %}Détails Utilisateur{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h1 class="h3 mb-0 text-white">Détails de l'utilisateur</h1>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th class="w-25 bg-light">Id</th>
                        <td>{{ user.id }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Email</th>
                        <td>{{ user.email }}</td>
                    </tr>
                    <tr>
                        <th class="bg-light">Rôles</th>
                        <td>
                            {% for role in user.roles %}
                                <span class="badge bg-secondary">{{ role }}</span>
                            {% endfor %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                    &larr; Retour à la liste
                </a>
                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning text-white">
                    Modifier
                </a>
                {{ include('user/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
