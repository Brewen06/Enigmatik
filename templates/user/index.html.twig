{% extends 'base.html.twig' %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block body %}
<div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h1 class="h3 mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i>Liste des utilisateurs</h1>
        <a href="{{ path('app_user_new') }}" class="btn btn-light btn-sm fw-bold text-primary">
            <i class="bi bi-plus-lg me-1"></i> Créer un utilisateur
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4">Id</th>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td class="ps-4 text-muted">#{{ user.id }}</td>
                        <td class="fw-bold">{{ user.email }}</td>
                        <td>
                            {% for role in user.roles %}
                                {% if role == 'ROLE_ADMIN' %}
                                    <span class="badge bg-danger">ADMIN</span>
                                {% elseif role == 'ROLE_PROF' %}
                                    <span class="badge bg-success">PROF</span>
                                {% else %}
                                    <span class="badge bg-secondary">USER</span>
                                {% endif %}
                            {% endfor %}
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm" role="group">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-outline-primary btn-sm" title="Voir">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-outline-warning btn-sm" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-person-x fs-1 d-block mb-3"></i>
                            Aucun utilisateur trouvé
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
