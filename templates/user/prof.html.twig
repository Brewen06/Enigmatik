{% extends 'base.html.twig' %}

{% block title %}Liste des Professeurs{% endblock %}

{% block body %}
<div class="prof-list">
    <div class="prof-list__header">
        <h1 class="prof-list__title">👨‍🏫 Liste des Professeurs</h1>
        <a href="{{ path('app_user_new') }}" class="btn btn-success">
            + Nouveau Professeur
        </a>
    </div>

    <div class="card prof-list__card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4">ID</th>
                            <th class="py-3 px-4">Email</th>
                            <th class="py-3 px-4">Rôles</th>
                            <th class="py-3 px-4 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="px-4">{{ user.id }}</td>
                            <td class="px-4 prof-list__email">{{ user.email }}</td>
                            <td class="px-4">
                                {% for role in user.roles %}
                                    <span class="badge bg-info text-dark me-1">{{ role }}</span>
                                {% endfor %}
                            </td>
                            <td class="px-4 text-end">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary me-1">Voir</a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                Aucun professeur trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}