{% extends 'base.html.twig' %}

{% block title %}Liste des Professeurs{% endblock %}

{% block body %}
<div class="tw-container tw-mx-auto tw-py-8">
    <div class="tw-flex tw-justify-between tw-items-center tw-mb-6">
        <h1 class="tw-text-3xl tw-font-bold tw-text-gray-800">👨‍🏫 Liste des Professeurs</h1>
        <a href="{{ path('app_user_new') }}" class="btn btn-success">
            + Nouveau Professeur
        </a>
    </div>

    <div class="card tw-shadow-md tw-border-0">
        <div class="card-body tw-p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped tw-mb-0 tw-align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="tw-py-3 tw-px-4">ID</th>
                            <th class="tw-py-3 tw-px-4">Email</th>
                            <th class="tw-py-3 tw-px-4">Rôles</th>
                            <th class="tw-py-3 tw-px-4 tw-text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="tw-px-4">{{ user.id }}</td>
                            <td class="tw-px-4 tw-font-medium">{{ user.email }}</td>
                            <td class="tw-px-4">
                                {% for role in user.roles %}
                                    <span class="badge bg-info text-dark tw-mr-1">{{ role }}</span>
                                {% endfor %}
                            </td>
                            <td class="tw-px-4 tw-text-right">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary tw-mr-1">Voir</a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="tw-text-center tw-py-8 tw-text-gray-500">
                                Aucun professeur trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}