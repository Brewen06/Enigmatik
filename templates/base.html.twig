                                    <li><a class="dropdown-item" href="{{ path('app_equipe_classement') }}">Classement équipes</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_user_index') }}">Utilisateurs</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_jeu_index') }}">
                                    <i class="bi bi-joystick me-1"></i> Jeu
