<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Enigmatik{% endblock %}</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      prefix: 'tw-',
      corePlugins: {
        preflight: false, // Disable preflight to avoid conflicts with Bootstrap
      }
    }
  </script>

  {% block javascripts %}
  {% block importmap %}{{ importmap('app') }}{% endblock %}
  {% endblock %}
</head>

<body class="d-flex flex-column min-vh-100 bg-light">
    <header class="mb-5">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow fixed-top">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="{{ path('app_index') }}">
                    <span class="fs-4">🧩</span> 
                    <span>Enigmatik</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_equipe_creer') }}">
                                <i class="bi bi-people-fill me-1"></i> Créer une équipe
                            </a>
                        </li>
                        
                        {% if is_granted('ROLE_PROF') or is_granted('ROLE_ADMIN') %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownEquipes" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-trophy-fill me-1"></i> Équipes
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarDropdownEquipes">
                                    <li><a class="dropdown-item" href="{{ path('app_equipe_index') }}">Liste des équipes</a></li>
                                </ul>
                            </li>
                            
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownUsers" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-badge-fill me-1"></i> Utilisateurs
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarDropdownUsers">
                                    <li><a class="dropdown-item" href="{{ path('app_user_index') }}">Liste des utilisateurs</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_user_new') }}">Créer un utilisateur</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_page_prof')}}">Page des Professeurs</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropDownEnigmes" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-puzzle-fill me-1"></i> Énigmes
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarDropDownEnigmes">
                                    <li><a class="dropdown-item" href="{{ path('app_enigme_index') }}">Liste des énigmes</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_enigme_creer') }}">Créer une énigme</a></li>
                                </ul>
                            </li>
                        {% endif %}

                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_admin') }}">
                                    <i class="bi bi-gear-fill me-1"></i> Administration
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                    
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> {{ app.user.email }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="navbarDropdownUser">
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">Se déconnecter</a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-light px-3 ms-2" href="{{ path('app_login') }}">Se connecter</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-5 pt-5 mb-5 flex-grow-1">
        {% block body %}{% endblock %}
    </div>

     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
    crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <div class="mb-3">
                <span class="fs-4">🧩</span> <span class="fw-bold">Enigmatik</span>
            </div>
            <p class="mb-2 text-secondary">&copy; {{ "now"|date("Y") }} Enigmatik. Tous droits réservés.</p>
            <p class="small text-secondary mb-0">Développé avec Symfony pour apprendre l'informatique en s'amusant.</p>
        </div>
    </footer>
  </body>

</html>