{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <section class="home-mission">
        <div class="home-mission__note">
            <div class="home-mission__tape home-mission__tape--left" aria-hidden="true"></div>
            <div class="home-mission__tape home-mission__tape--right" aria-hidden="true"></div>
            <div class="home-mission__note-body">
                <h1 class="home-mission__title">Bienvenue sur Enigmatik</h1>
                <p class="home-mission__subtitle">Découvrez des énigmes sur l'informatique et testez vos connaissances.</p>
            </div>
        </div>
        <div class="home-mission__actions">
            {% if equipe is defined and equipe %}
                <a href="{{ path('app_jeu_index', {'equipe_id': equipe.id}) }}" class="btn btn-success home-mission__cta home-mission__cta--primary">Reprendre la partie</a>
                <a href="{{ path('app_equipe_creer') }}" class="btn btn-outline-secondary home-mission__cta">Créer une autre équipe</a>
            {% else %}
                <a href="{{ path('app_equipe_creer') }}" class="btn btn-primary home-mission__cta home-mission__cta--primary">Créer votre équipe</a>
            {% endif %}
        </div>
    </section>
{% endblock %}