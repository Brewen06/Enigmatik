{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <div class="tw-text-center tw-mt-10 tw-p-10 tw-bg-gray-100 tw-rounded-xl tw-shadow-lg">
        <h1 class="tw-text-5xl tw-font-bold tw-mb-6 tw-text-blue-600">Bienvenue sur Enigmatik</h1>
        <p class="tw-text-xl tw-text-gray-700 tw-mb-8">Découvrez des énigmes sur l'informatique et testez vos connaissances en équipe !</p>
        
        <div class="tw-flex tw-justify-center tw-space-x-4">
            {% if equipe is defined and equipe %}
                <div class="tw-bg-white tw-rounded-lg tw-shadow tw-p-4 tw-mr-4 tw-flex tw-items-center tw-gap-3">
                    {% if equipe.avatar %}
                        <img src="{{ asset(equipe.avatar.image) }}" alt="{{ equipe.avatar.nom }}" class="tw-w-12 tw-h-12 tw-rounded-full tw-object-cover">
                    {% endif %}
                    <div class="tw-text-left">
                        <p class="tw-text-xs tw-text-gray-500 tw-uppercase tw-mb-0">Équipe</p>
                        <p class="tw-font-semibold tw-text-gray-800 tw-mb-0">{{ equipe.nom }}</p>
                    </div>
                </div>
                <a href="{{ path('app_jeu_index', {'equipe_id': equipe.id}) }}" class="btn btn-success btn-lg tw-font-bold tw-px-8 tw-py-3 tw-rounded-full tw-shadow-md hover:tw-shadow-xl tw-transition tw-duration-300">
                    ▶ Reprendre la partie ({{ equipe.nom }})
                </a>
            {% else %}
                <a href="{{ path('app_equipe_creer') }}" class="btn btn-primary btn-lg tw-font-bold tw-px-8 tw-py-3 tw-rounded-full tw-shadow-md hover:tw-shadow-xl tw-transition tw-duration-300">
                    Créer votre équipe
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}