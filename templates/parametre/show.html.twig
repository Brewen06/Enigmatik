{% extends 'base.html.twig' %}

{% block title %}Détails Paramètre{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h1 class="h3 mb-0 text-white">Détails du paramètre</h1>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th class="w-25 bg-light">Id</th>
                        <td>{{ parametre.id }}</td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex gap-2 mt-4">
                <a href="{{ path('app_parametre_index') }}" class="btn btn-secondary">
                    &larr; Retour à la liste
                </a>
                <a href="{{ path('app_parametre_edit', {'id': parametre.id}) }}" class="btn btn-warning text-white">
                    Modifier
                </a>
                {{ include('parametre/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
