{{ form_start(form, {'attr': {'class': 'enigme-form'}}) }}
<div class="enigme-form__section">
    {{ form_widget(form) }}
</div>
<div class="enigme-form__actions mt-3">
    <button class="btn btn-primary">
        {{ button_label|default('Enregistrer') }}
    </button>
</div>
{{ form_end(form) }}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const typeRadios = document.querySelectorAll(
            'input[name="parametre[reponseType]"]',
        );
        const valeurHelp =
            document.querySelector("#parametre_valeur").nextElementSibling;
        const choicesHelp =
            document.querySelector("#parametre_choix").nextElementSibling;

        function updateHints() {
            const selectedType = document.querySelector(
                'input[name="parametre[reponseType]"]:checked',
            );
            if (!selectedType) return;

            if (selectedType.value === "systeme") {
                valeurHelp.textContent =
                    "Exemples : Oui, Non, Actif, ou un texte court.";
                choicesHelp.textContent =
                    "Optionnel : Liste de configurations associées (une par ligne).";
            } else if (selectedType.value === "temps") {
                valeurHelp.textContent =
                    "Valeur en secondes ou minutes (ex: 60, 3600).";
                choicesHelp.textContent =
                    "Optionnel : Paliers de temps si le paramètre évolue (une par ligne).";
            } else if (selectedType.value === "nombre") {
                valeurHelp.textContent =
                    "Un chiffre entier (ex: 3 pour les tentatives, 100 pour les points).";
                choicesHelp.textContent =
                    "Optionnel : Paliers numériques (une par ligne).";
            }
        }

        typeRadios.forEach((radio) => {
            radio.addEventListener("change", updateHints);
        });

        // Set initial state
        updateHints();
    });
</script>
