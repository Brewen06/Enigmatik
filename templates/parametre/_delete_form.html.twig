<form method="post" action="{{ path('app_parametre_delete', {'id': parametre.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ parametre.id) }}">
    <button class="btn">Supprimer</button>
</form>
